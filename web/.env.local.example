# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored and MUST NOT be committed.
#
# API base URL resolution order (see src/lib/api.ts):
#   1. VITE_EDGE_URL      — set this to hit the Vercel/Hono edge in dev/prod
#   2. VITE_PIPELINE_URL  — set this to hit the Modal pipeline directly, bypassing edge
#   3. http://127.0.0.1:8001 — automatic fallback for the local stub server

# Modal deployment URL (from `modal deploy modal_app.py`).
VITE_PIPELINE_URL=https://<username>--kepler-pipeline-web.modal.run

# Uncomment to route through the Vercel edge instead.
# VITE_EDGE_URL=https://<your-edge>.vercel.app
