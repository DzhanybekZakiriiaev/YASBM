# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored and MUST NOT be committed.
#
# Mirror each var into Vercel with `vercel env add <NAME> production` before deploying.

# Modal pipeline URL (from `modal deploy pipeline/modal_app.py`).
MODAL_PIPELINE_URL=https://<username>--kepler-pipeline-web.modal.run

# Cloudflare R2 (S3-compatible object storage).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Anthropic API key for the verdict-card SSE stream.
ANTHROPIC_API_KEY=sk-ant-...

# The web app's origin — used for CORS on the edge functions.
ALLOWED_ORIGIN=http://localhost:5174
