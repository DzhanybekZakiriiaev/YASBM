# --- Modal pipeline ---
# Deployed URL of the FastAPI @app.asgi_app in pipeline/modal_app.py
MODAL_PIPELINE_URL=https://your-modal-deployment.modal.run

# --- Cloudflare R2 (S3-compatible) ---
# Account ID from the Cloudflare dashboard (top-right of R2 page)
R2_ACCOUNT_ID=
# Access key + secret from R2 > Manage R2 API Tokens (with Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kepler-uploads

# --- Anthropic ---
# console.anthropic.com > Settings > API Keys
ANTHROPIC_API_KEY=

# --- CORS ---
# Web app origin. Local dev = http://localhost:5174; prod = https://kepler.example.com
ALLOWED_ORIGIN=http://localhost:5174
